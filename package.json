{
  "name": "nodewarden",
  "version": "1.6.1",
  "description": "Minimal Bitwarden-compatible server running on Cloudflare Workers",
  "author": "shuaiplus",
  "license": "LGPL-3.0",
  "main": "src/index.ts",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "wrangler dev -c wrangler.toml",
    "dev:kv": "wrangler dev -c wrangler.kv.toml",
    "dev:demo": "vite --config webapp/vite.config.ts --mode demo --host 127.0.0.1 --port 5174",
    "build": "vite build --config webapp/vite.config.ts",
    "build:demo": "vite build --config webapp/vite.config.ts --mode demo && node scripts/pages-spa-redirects.cjs",
    "domains:sync": "node scripts/sync-global-domains.mjs",
    "i18n": "node scripts/i18n-validate.cjs",
    "i18n:validate": "node scripts/i18n-validate.cjs",
    "i18n:report": "node scripts/i18n-report.cjs",
    "deploy": "wrangler deploy",
    "deploy:kv": "node scripts/ensure-kv.cjs && wrangler deploy -c wrangler.kv.toml",
    "deploy:demo": "npm run build:demo && wrangler pages deploy dist --project-name nw-demo",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:api": "oxlint src shared --deny-warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:webapp": "vitest run --config vitest.webapp-jsdom.config.ts",
    "coverage:webapp": "vitest run --config vitest.webapp.config.ts --coverage",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "typecheck:webapp": "tsc -p webapp/tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "bitwarden",
    "vaultwarden",
    "cloudflare",
    "workers",
    "password-manager"
  ],
  "cloudflare": {
    "bindings": {
      "JWT_SECRET": {
        "description": "Use a strong random string (32+ characters recommended)"
      },
      "DB": {
        "description": "D1 database for storing vault data"
      },
      "ATTACHMENTS": {
        "description": "R2 bucket for storing file attachments"
      },
      "ATTACHMENTS_KV": {
        "description": "Optional KV namespace fallback for attachment/send-file storage"
      }
    }
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.18",
    "@cloudflare/workers-types": "4.20260621.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@preact/preset-vite": "2.10.5",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/preact": "3.2.4",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.4",
    "@vitest/coverage-istanbul": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "istanbul-lib-coverage": "3.2.2",
    "jsdom": "26.1.0",
    "opencc-js": "1.3.1",
    "oxlint": "1.71.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@simplewebauthn/server": "13.3.1",
    "@tanstack/react-query": "5.101.0",
    "@zip.js/zip.js": "2.8.26",
    "fflate": "0.8.3",
    "lucide-preact": "1.21.0",
    "preact": "10.29.2",
    "qrcode-generator": "2.0.4",
    "wouter": "3.10.0"
  }
}
